# =============================================================================
# DripEmails — environment template
# =============================================================================
# Copy to ".env" in the project root (same directory as manage.py):
#   cp .env.example .env
# Then edit .env with real secrets. Never commit .env (it is gitignored).
#
# Used by:
#   - dripemails/settings.py       (local / default Django settings via django-environ)
#   - dripemails/live.py             (production / live settings via python-dotenv)
#
# Note: There is no demo.py in this repo; production-style settings live in live.py.
# =============================================================================

# --- Core Django (both) ---
SECRET_KEY=change-me-to-a-long-random-string
# Dev (settings.py): True | False
DEBUG=True

# --- Database ---
# settings.py: single DATABASE_URL (SQLite dev default in code, or Postgres URL)
DATABASE_URL=sqlite:///db.sqlite3
# live.py: discrete Postgres variables (ignored by settings.py if you only use DATABASE_URL)
DB_NAME=dripemails
DB_USER=dripemails
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# --- Site URLs ---
SITE_URL=http://localhost:8000
DEFAULT_URL=http://localhost:8000/

# --- Outbound email (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=DripEmails <noreply@dripemails.org>
FOUNDERS_EMAIL=founders@dripemails.org

# --- Celery & Redis ---
CELERY_ENABLED=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db
REDIS_URL=redis://127.0.0.1:6379/1

# --- Ollama (AI generation) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=300

# --- Google / Gmail OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dripemails.org/api/gmail/callback/

# --- Product / compliance ---
DATA_RETENTION_DAYS=30
SHOW_ADDRESS_NAME_MODAL_NEW_ACCOUNTS=True
FOLLOW_UP_AFTER_ADDRESS_CAMPAIGN_ID=
FOLLOW_UP_AFTER_ADDRESS_EMAIL_ID=
